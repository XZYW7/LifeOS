# LLM Configuration / LLM 配置

# Provider: deepseek, openai, ollama / 提供商
# Default: deepseek
LLM_PROVIDER=deepseek

# Model name / 模型名称
# Default: deepseek-chat
LLM_MODEL=deepseek-chat

# API Key / API 密钥
LLM_API_KEY=sk-xxxxx

# Base URL (optional) / 自定义 API 端点（可选）
# Default: https://api.deepseek.com/v1 (for deepseek)
# LLM_BASE_URL=https://api.deepseek.com/v1

# Server Port (optional) / 后端端口（可选）
# Default: 3456
# LIFEOS_PORT=3456

# ── Examples / 配置示例 ──

# OpenAI GPT-4
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-proj-xxxxx
# LLM_BASE_URL=https://api.openai.com/v1

# Ollama (local)
# LLM_PROVIDER=ollama
# LLM_MODEL=llama2
# LLM_BASE_URL=http://localhost:11434/v1
